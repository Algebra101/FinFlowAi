# ==============================
# FinCore AI — Environment Variables
# ==============================
# Copy this file to .env and fill in your real keys.

# --- Squad API ---
SQUAD_API_KEY=your_squad_sandbox_api_key_here
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com

# --- Mono Open Banking ---
MONO_SECRET_KEY=your_mono_secret_key_here
MONO_PUBLIC_KEY=your_mono_public_key_here
MONO_BASE_URL=https://api.withmono.com/v2

# --- Database ---
DATABASE_URL=sqlite:///./fincore.db

# --- Service Ports ---
API_GATEWAY_PORT=8000
PAYMENT_SERVICE_PORT=8001
BANKING_SERVICE_PORT=8002
FRAUD_SERVICE_PORT=8003
CREDIT_SERVICE_PORT=8004
FORECASTING_SERVICE_PORT=8005
IDENTITY_SERVICE_PORT=8006
